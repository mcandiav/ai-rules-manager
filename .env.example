# AI Rules Manager — local configuration (Windows first)

# Prefer one-shot install (creates this file if missing):
#   irm https://raw.githubusercontent.com/mcandiav/ai-rules-manager/master/install.ps1 | iex
# Or from a clone: .\install.ps1
#
# Defaults for a new user — no workspace root:
#   - API_PORT / WEB_PORT
#   - HOST_HOME_ROOT = %USERPROFILE% (set by start.ps1)
#   - HOST_DRIVE_MAPPINGS = all fixed drives (set by start.ps1)
#
# Projects are registered one-by-one in the UI with their full path
# (including F:\...). start.ps1 mounts every fixed drive so any path works.

COMPOSE_PROJECT_NAME=ai-rules-manager

API_PORT=8002
WEB_PORT=3002
SQLITE_PATH=/data/sqlite/rules-manager.db
POLL_INTERVAL_MS=30000
NODE_ENV=production

# Filled automatically by start.ps1
HOST_HOME_ROOT=
HOST_DRIVE_MAPPINGS=

# Optional legacy overrides (not required on Windows):
# HOST_WORKSPACE_ROOT=
# CONTAINER_WORKSPACE_ROOT=/host/workspace
# CONTAINER_HOME_ROOT=/host/home

# Reglas Estandar host path is discovered from the Docker bind mount of
# ./Reglas Estandar (install folder). It is not configurable.

# Release identity (VERSION@GIT_HASH) is baked into the API image at build time
# from the VERSION file + git rev-parse. The UI badge reads it from GET /health.
