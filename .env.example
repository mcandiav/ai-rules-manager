# AI Rules Manager — configuración local

API_PORT=8000
WEB_PORT=3001
SQLITE_PATH=/data/sqlite/rules-manager.db
POLL_INTERVAL_MS=30000
NODE_ENV=development

# Host path prefix used when registering Windows/macOS projects.
# Inside Docker this root is mounted at CONTAINER_WORKSPACE_ROOT.
HOST_WORKSPACE_ROOT=D:/MCP/workspace
CONTAINER_WORKSPACE_ROOT=/host/workspace
