# Base Windows config — copy to .env only if you need overrides.
# Normal install: git clone + docker compose up -d --build
# (compose.yaml already mounts C: and D: with these defaults)

COMPOSE_PROJECT_NAME=ai-rules-manager
API_PORT=8002
WEB_PORT=3002

# Windows user profile (Compose expands this from the host)
HOST_HOME_ROOT=${USERPROFILE}

# Project drives (V1 base = C: and D:)
HOST_DRIVE_MAPPINGS=C:/:/host/c;D:/:/host/d
