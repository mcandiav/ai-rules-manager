# AI Rules Manager — optional local overrides (Windows)

# Not required for a normal install. Defaults live in compose.yaml:
#   API_PORT=8002  WEB_PORT=3002
#   HOST_HOME_ROOT=%USERPROFILE%
#   drives C:–M: mounted
#
# Copy only if you need to change ports:
#   copy .env.example .env

COMPOSE_PROJECT_NAME=ai-rules-manager
API_PORT=8002
WEB_PORT=3002
