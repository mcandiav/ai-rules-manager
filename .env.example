# AI Rules Manager — local configuration

# Copy to .env and adjust for your machine:
#   cp .env.example .env

COMPOSE_PROJECT_NAME=ai-rules-manager

API_PORT=8002
WEB_PORT=3002
SQLITE_PATH=/data/sqlite/rules-manager.db
POLL_INTERVAL_MS=30000
NODE_ENV=development

# Mount of folders you want the API to read/write from the host.
# Workspace: where governed projects live.
# Home: where global AI app configs live (~/.codex, ~/.claude, ~/.cursor, ...).
#
# Windows examples:
#   HOST_WORKSPACE_ROOT=D:/MCP/workspace
#   HOST_HOME_ROOT=C:/Users/YourUser
# Linux/macOS examples:
#   HOST_WORKSPACE_ROOT=/home/you/projects
#   HOST_HOME_ROOT=/home/you
HOST_WORKSPACE_ROOT=
CONTAINER_WORKSPACE_ROOT=/host/workspace
HOST_HOME_ROOT=
CONTAINER_HOME_ROOT=/host/home

# Release identity shown in UI badge and /health (VERSION@GIT_HASH)
APP_VERSION=0.1.4
GIT_HASH=dev
